# ==========================================
# ANIKA CONTROL OS - ENVIRONMENT VARIABLES
# ==========================================
# Copy this file to .env.local and fill in your actual values
# See ENVIRONMENT.md for complete documentation
#
# SECURITY: Never commit .env.local to git!
# ==========================================

# ------------------------------------------
# DATABASE & AUTHENTICATION (REQUIRED)
# ------------------------------------------
# Supabase project URL and public API key
# Get these from: https://app.supabase.com → Your Project → Settings → API
#
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_anon_key_here

# ------------------------------------------
# MAPS & ROUTING (REQUIRED)
# ------------------------------------------
# Google Maps API key for map rendering, routing, and geocoding
# Get from: https://console.cloud.google.com/apis/credentials
# Required APIs: Maps JavaScript API, Routes API, Geocoding API, Distance Matrix API
#
VITE_GOOGLE_MAPS_KEY=AIzaSyC_your_google_maps_api_key_here

# ------------------------------------------
# ERROR TRACKING & MONITORING (OPTIONAL)
# ------------------------------------------
# Sentry DSN for error reporting (recommended for production)
# Get from: https://sentry.io → Project Settings → Client Keys (DSN)
#
VITE_SENTRY_DSN=https://your_key@o123456.ingest.us.sentry.io/7890123

# Sentry auth token for uploading source maps during build
# Get from: https://sentry.io → Settings → Auth Tokens
# Permissions needed: project:write, org:read
# NOTE: Only needed for production builds, not for local development
#
# SENTRY_AUTH_TOKEN=sntrys_your_auth_token_here

# ------------------------------------------
# QUICKBOOKS INTEGRATION (OPTIONAL)
# ------------------------------------------
# QuickBooks OAuth credentials for automated invoicing
# Get from: https://developer.intuit.com/app/developer/qbo/docs/get-started
#
# Client ID (safe to expose in browser)
VITE_QB_CLIENT_ID=your_quickbooks_client_id

# OAuth redirect URI (must match QuickBooks app configuration exactly)
# Development:
VITE_QB_REDIRECT_URI=http://localhost:8080/auth/quickbooks/callback
# Production:
# VITE_QB_REDIRECT_URI=https://dispatch.anikalogistics.com/auth/quickbooks/callback

# QuickBooks environment (sandbox for development, production for live)
VITE_QB_ENVIRONMENT=sandbox

# IMPORTANT: QB_CLIENT_SECRET must NEVER go in this file!
# Set it in Supabase Edge Functions secrets only:
#   supabase secrets set QB_CLIENT_SECRET=your_secret_here

# ------------------------------------------
# PUSH NOTIFICATIONS (FUTURE - NOT REQUIRED)
# ------------------------------------------
# OneSignal credentials for driver push notifications
# Get from: https://onesignal.com → Settings → Keys & IDs
# NOTE: Feature planned for Phase 10, not yet implemented
#
# VITE_ONESIGNAL_APP_ID=12345678-1234-1234-1234-123456789012
# VITE_ONESIGNAL_API_KEY=your_onesignal_rest_api_key

# ==========================================
# LOCAL DEVELOPMENT TIPS
# ==========================================
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in the REQUIRED variables (Supabase, Google Maps)
# 3. Optional variables can be added as needed
# 4. Restart dev server after changes: npm run dev
# 5. Never commit .env.local to git (it's in .gitignore)
#
# For detailed setup instructions, see:
# - PROJECT_README.md (Quick Start section)
# - ENVIRONMENT.md (Complete variable reference)
# ==========================================
